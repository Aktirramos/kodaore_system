# Production environment template
# Copy this file to .env.production and replace placeholder values.

DATABASE_URL="postgresql://USER:PASSWORD@DB_HOST:5432/kodaore?schema=public"
NEXTAUTH_SECRET="REPLACE_WITH_MIN_32_CHAR_RANDOM_SECRET"
NEXTAUTH_URL="https://kodaore.example.com"
TURNSTILE_SECRET_KEY="REPLACE_WITH_TURNSTILE_SECRET"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="REPLACE_WITH_TURNSTILE_SITE_KEY"

# Optional, only if you use seed scripts in non-production environments
# SEED_DEFAULT_PASSWORD="ChangeMe-Long-Unique-Password"
