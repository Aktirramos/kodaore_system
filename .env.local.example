# Development-only overrides. Copy to .env.local (ignored by git).
# Next.js loads .env.local with higher priority than .env in `next dev`.
# Prisma CLI does NOT read .env.local; when running prisma commands pass
# DATABASE_URL inline or via `dotenv -e .env.local -- ...`.
#
# Setup (one-time):
#   sudo -u postgres psql -c "CREATE USER kodaore_dev WITH PASSWORD 'dev_local_2026';"
#   sudo -u postgres psql -c "CREATE DATABASE kodaore_system OWNER kodaore_dev;"
#   sudo -u postgres psql -d kodaore_system -c "ALTER SCHEMA public OWNER TO kodaore_dev;"
#   DATABASE_URL=postgresql://... npx prisma migrate deploy
#   DATABASE_URL=postgresql://... SEED_DEFAULT_PASSWORD=Kodaore2026! npx prisma db seed

DATABASE_URL="postgresql://kodaore_dev:dev_local_2026@localhost:5432/kodaore_system"
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="replace-with-a-secure-secret-for-local-dev"
ENCRYPTION_SECRET="replace-with-a-secure-secret-for-local-dev"
SEED_DEFAULT_PASSWORD="Kodaore2026!"
